# Managed by Ansible (roles/backend) — edit group_vars/web/vars.yml and vault.yml, not this file.
DATABASE_URL={{ database_url }}
JWT_SECRET_KEY={{ jwt_secret_key }}
GOOGLE_API_KEY={{ google_api_key }}

# Nginx proxies the frontend and API from the same origin (see the nginx role's
# /api/ location), so browser requests never hit CORS. This regex only matters
# for direct, non-proxied calls to the backend port.
ALLOWED_ORIGIN_REGEX=https://{{ domain_name | regex_escape }}

# Real AWS S3 (S3_ENDPOINT_URL intentionally unset — boto3 defaults to AWS).
# No static keys either: the EC2 instance's IAM role supplies credentials via
# boto3's default credential chain, per backend/app/core/storage.py.
S3_BUCKET={{ s3_bucket }}
S3_PUBLIC_URL_BASE={{ s3_public_url_base }}
S3_REGION={{ s3_region }}
