DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/contoso
JWT_SECRET_KEY=dev-secret-change-me-before-production

# Chatbot LLM (customer support chat). Points at Ollama running natively on
# your machine; run `ollama pull mistral` once so the model is available
# before the first chat message. docker-compose and k8s reach this same
# host-installed Ollama via host.docker.internal, rather than running their
# own containerized Ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Object storage (product image uploads). Points at MinIO for local/dev use;
# for real AWS S3, leave S3_ENDPOINT_URL unset and set S3_PUBLIC_URL_BASE to
# the bucket's (or CloudFront's) public URL.
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL_BASE=http://localhost:9000/contoso-images
S3_BUCKET=contoso-images
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
